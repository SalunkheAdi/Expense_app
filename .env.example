# Shared Expenses App — Environment Variables
# Copy this file to .env and fill in your values

PORT=3001

# PostgreSQL connection string
# Local: postgresql://postgres:YOUR_PASSWORD@localhost:5432/shared_expenses
# Production: use your hosted DB URL (Render, Railway, Neon, Supabase, etc.)
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/shared_expenses

# Frontend API URL — used by the React app at build time
# Local dev: http://localhost:3001
# Production: https://your-backend-domain.com
VITE_API_URL=http://localhost:3001

# ── Business Logic Config ─────────────────────────────────────────────────────

# USD to INR exchange rate for importing the Goa trip expenses
# Per the assignment context: fixed historical rate used during the trip
USD_TO_INR_RATE=83.0

# Name of the flatmate group created on first CSV import
DEFAULT_GROUP_NAME=Flat 204
DEFAULT_GROUP_DESC=Flatmates shared expenses group

# Active membership dates for the assignment CSV context
# Meera left the flat: her last active date
MEERA_LEFT_DATE=2026-03-31

# Sam joined the flat: his first active date
SAM_JOIN_DATE=2026-04-15

# Earliest date in the expense history (used to infer year for short dates like "Mar 14")
EXPENSE_HISTORY_START_DATE=2026-02-01
